<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Si el archivo o directorio solicitado existe, sírvelo directamente
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Si no existe, redirige todo al index.html para que React Router se encargue de la ruta
  RewriteRule ^ index.html [QSA,L]
</IfModule>
